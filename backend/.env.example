APP_NAME=Sui Portfolio Assistant API
NODE_ENV=development
PORT=4000
API_PREFIX=api
FRONTEND_ORIGIN=http://localhost:3000
SUI_NETWORK=mainnet
SUI_RPC_URL=
SUI_RPC_TIMEOUT_MS=10000
SUI_RPC_MAX_RETRIES=3
SUI_RPC_RATE_LIMIT_PER_SECOND=10
SUI_CACHE_BALANCE_TTL_SECONDS=30
SUI_CACHE_OBJECT_TTL_SECONDS=300
SUI_CACHE_TRANSACTION_TTL_SECONDS=60
SUI_CACHE_EVENT_TTL_SECONDS=120
SUI_CACHE_STALE_SECONDS=300
SUI_SYNC_PAGE_SIZE=50

MONGODB_ENABLED=false
MONGODB_URI=mongodb://127.0.0.1:27017/sui-portfolio

REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
QUEUE_NAME=wallet-sync

AUTH_TOKEN_SECRET=dev-only-change-me
AUTH_CHALLENGE_TTL_SECONDS=300
AUTH_SESSION_TTL_SECONDS=1800
AUTH_REFRESH_TTL_SECONDS=1800

MEMWAL_ENABLED=false
MEMWAL_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=https://relayer.memwal.ai
MEMWAL_NAMESPACE=wallet-chat
